    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "checkJs": true,
        "ignoreDeprecations": "6.0",
        "types": ["vite/client"]
    },
    "include": [
        "src/**/*",
        "env.d.ts"
    ],
